{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "ServiceBus": {
    "FullyQualifiedNamespace": "your-namespace.servicebus.windows.net",
    "TopicName": "fieldops-events",
    "SubscriptionName": "assethub-sync"
  },
  "AssetHub": {
    "BaseUrl": "http://localhost:9090",
    "TokenUrl": "http://localhost:9090/oauth/token",
    "ClientId": "mock-client",
    "ClientSecret": "mock-secret",
    "RefreshSkewSeconds": 60
  },
  "Resilience": {
    "Retry": {
      "MaxRetryAttempts": 4,
      "BaseDelayMs": 500,
      "UseJitter": true
    },
    "CircuitBreaker": {
      "FailureRatio": 0.5,
      "MinimumThroughput": 8,
      "SamplingDurationSeconds": 30,
      "BreakDurationSeconds": 60
    },
    "Timeout": {
      "AttemptTimeoutSeconds": 15,
      "TotalTimeoutSeconds": 45
    }
  },
  "Dlq": {
    "QueueName": "fieldops-events",
    "MaxMessagesPerRun": 100
  }
}
